[Unit]
Description=SvelteKit Vendure Storefront
After=network-online.target

[Container]
Image={{ APP_IMAGE }}
AutoUpdate=registry
PublishPort={{ PORT }}:{{ PORT }}
Environment=PORT={{ PORT }}
Environment=NODE_ENV={{ NODE_ENV }}
Environment=PUBLIC_SHOPAPI_DEV_URL={{ PUBLIC_SHOPAPI_DEV_URL }}
Environment=PUBLIC_SHOPAPI_PROD_URL={{ PUBLIC_SHOPAPI_PROD_URL }}
Environment=PUBLIC_REQUIRE_EMAIL_VERIFICATION={{ PUBLIC_REQUIRE_EMAIL_VERIFICATION }}
Environment=PUBLIC_DEFAULT_CURRENCY={{ PUBLIC_DEFAULT_CURRENCY }}
Environment=PUBLIC_VENDURE_CHANNEL_TOKEN={{ PUBLIC_VENDURE_CHANNEL_TOKEN }}
Environment=PUBLIC_VENDURE_LANGUAGE={{ PUBLIC_VENDURE_LANGUAGE }}
Environment=PUBLIC_VENDURE_SUPPORT_MULTI_LANGUAGE={{ PUBLIC_VENDURE_SUPPORT_MULTI_LANGUAGE }}
Environment=PUBLIC_VENDURE_MULTI={{ PUBLIC_VENDURE_MULTI }}
Environment=PUBLIC_ORGANIZATION={{ PUBLIC_ORGANIZATION }}
Environment=PUBLIC_SITE_ADDRESS={{ PUBLIC_SITE_ADDRESS }}
Environment=PUBLIC_SITE_CITY={{ PUBLIC_SITE_CITY }}
Environment=PUBLIC_SITE_STATE={{ PUBLIC_SITE_STATE }}
Environment=PUBLIC_SITE_ZIP={{ PUBLIC_SITE_ZIP }}
Environment=PUBLIC_SITE_EMAIL={{ PUBLIC_SITE_EMAIL }}
Environment=PUBLIC_SITE_NAME={{ PUBLIC_SITE_NAME }}
Environment=PUBLIC_SITE_PHONE={{ PUBLIC_SITE_PHONE }}
Environment=PUBLIC_SITE_IMAGE={{ PUBLIC_SITE_IMAGE }}
Environment=PUBLIC_SITE_URL={{ PUBLIC_SITE_URL }}
Environment=PUBLIC_FACEBOOK_URL={{ PUBLIC_FACEBOOK_URL }}
Environment=PUBLIC_TWITTER_URL={{ PUBLIC_TWITTER_URL }}
Environment=PUBLIC_YOUTUBE_URL={{ PUBLIC_YOUTUBE_URL }}
Environment=PUBLIC_GOOGLE_TAG_MANAGER={{ PUBLIC_GOOGLE_TAG_MANAGER }}
AddHost=host.containers.internal:host-gateway
LogDriver=journald
LogOpt=tag={{ '{{.Name}}' }}

[Install]
WantedBy=multi-user.target
